# --- Core ---
# Anthropic API key for diff parsing and verdict prose
ANTHROPIC_API_KEY=

# Postgres connection string (Railway Postgres in prod, local Postgres in dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/threxa

# --- DataHub ---
# GMS endpoint of the DataHub instance loaded with showcase-ecommerce
DATAHUB_GMS_URL=http://localhost:8080
# Personal access token for that instance (Settings > Access Tokens)
DATAHUB_TOKEN=

# URL of the mcp-server-datahub sidecar (streamable HTTP transport)
MCP_SERVER_URL=http://localhost:8000/mcp

# --- GitHub ---
# Secret configured on the webhook of guarded repos
GITHUB_WEBHOOK_SECRET=
# Token with repo scope for posting comments and statuses
GITHUB_TOKEN=

# --- Optional ---
# Pre-seeded demo data for the dashboard, no backend required
NEXT_PUBLIC_DEMO_MODE=false

# DataHub UI base for dashboard click-through links
NEXT_PUBLIC_DATAHUB_UI_URL=http://localhost:9002
